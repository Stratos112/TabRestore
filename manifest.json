{
  "manifest_version": 3,
  "name": "TabRestore",
  "version": "1.1",
  "description": "Click 'Save Links' to backup current session to a .txt file. click 'Load .txt' to load a session from a file.",
  "icons": {
    "48": "icons/616487.png"
  },
  "content_scripts": [
    {
      "js": [
        "content_scripts/blankpage_content.js"
      ],
      "matches": [
        "http://www.blankwebsite.com/"
      ]
    }
  ],
  "permissions": [
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "*://*/*"
  ],
  "action": {
    "default_icon": "icons/616487.png",
    "default_title": "TabRestore",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "content_scripts/background.js"
  }
}