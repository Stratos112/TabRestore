{
  "manifest_version": 3,
  "name": "TabRestore",
  "version": "1.1",
  "description": "Click 'Save Links' to backup current session to a .txt file. click 'Load .txt' to load a session from a file.",
  "icons": {
    "48": "icons/616487.png"
  },
  "content_scripts": [
    {
      "js": [
        "content_scripts/blankpage_content.js"
      ],
      "matches": [
        "http://www.blankwebsite.com/"
      ]
    }
  ],
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "tabGroups"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "*://*/*"
  ],
  "action": {
    "default_icon": "icons/616487.png",
    "default_title": "TabRestore",
    "default_popup": "popup/popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tabrestore@sky",
      "strict_min_version": "109.0"
    }
  }
}
