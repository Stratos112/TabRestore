{
  "manifest_version": 3,
  "name": "TabRestore",
  "version": "1.1",
  "description": "Save your open tabs to a .txt file and restore them later. Simple session management for Chrome and Firefox.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "64": "icons/icon64.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "tabGroups"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "64": "icons/icon64.png",
      "128": "icons/icon128.png"
    },
    "default_title": "TabRestore",
    "default_popup": "popup/popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tabrestore@sky",
      "strict_min_version": "109.0"
    }
  }
}
