{
  "manifest_version": 3,
  "name": "TabRestore",
  "version": "1.1",
  "description": "Save your open tabs to a .txt file and restore them later. Simple session management for Chrome and Firefox.",
  "icons": {
    "128": "icons/616487_thumb.png"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "tabGroups"
  ],
  "action": {
    "default_icon": "icons/616487_thumb.png",
    "default_title": "TabRestore",
    "default_popup": "popup/popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tabrestore@sky",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}
